# Brain Dump production frontend
VITE_SUPPORT_EMAIL=support@braindump.app

# Brain Dump production backend
GOOGLE_CLIENT_ID=replace-with-production-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-production-google-oauth-client-secret
BRAIN_DUMP_PUBLIC_API_ORIGIN=https://api.braindump.app
BRAIN_DUMP_FRONTEND_ORIGIN=https://braindump.app
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_KV_TABLE=brain_dump_kv

# Keep scopes narrow for first public beta
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/tasks https://www.googleapis.com/auth/calendar.events

# Production operator settings
BRAIN_DUMP_STORAGE_PREFIX=brain-dump-prod
BRAIN_DUMP_ADMIN_TOKEN=replace-with-long-random-admin-token
