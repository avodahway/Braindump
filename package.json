{
  "name": "brain-dump-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:backend": "vite build --config vite.backend.config.ts",
    "preview": "vite preview --host 127.0.0.1",
    "start:backend": "node dist-server/nodeServer.js",
    "test": "vitest run",
    "validate:env": "node scripts/validate-production-env.mjs",
    "smoke:oauth": "node scripts/oauth-smoke-test.mjs",
    "rehearse:restore": "node scripts/backup-restore-rehearsal.mjs",
    "verify:deployment": "node scripts/verify-deployment.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  }
}
