# Frontend build
VITE_SUPPORT_EMAIL=support@example.com
VITE_PUBLIC_API_BASE_URL=https://api.example.com

# Public backend
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
BRAIN_DUMP_PUBLIC_API_ORIGIN=https://api.example.com
BRAIN_DUMP_FRONTEND_ORIGIN=https://braindump.example.com

# Optional backend settings
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/tasks https://www.googleapis.com/auth/calendar.events
BRAIN_DUMP_STORAGE_PREFIX=brain-dump
BRAIN_DUMP_ADMIN_TOKEN=replace-with-long-random-admin-token
BRAIN_DUMP_BETA_ACCESS_CODE=replace-with-private-beta-code
BRAIN_DUMP_MAX_JSON_BODY_BYTES=65536
BRAIN_DUMP_RATE_LIMIT_WINDOW_MS=60000
BRAIN_DUMP_RATE_LIMIT_MAX_REQUESTS=60
